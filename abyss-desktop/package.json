{
  "name": "abyss-desktop",
  "private": true,
  "version": "0.1.0",
  "description": "ABYSS — a walkable painterly underwater casino. Desktop build, Babylon.js 7 + WebGPU + Electron, shipped on Steam.",
  "author": { "name": "Eden Adiv", "email": "edenadiv1@gmail.com" },
  "homepage": "./",
  "main": "electron/main.js",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "electron:dev": "concurrently -k -n vite,electron -c green,blue \"vite\" \"wait-on tcp:5180 && tsc -p electron/tsconfig.json && cross-env NODE_ENV=development electron electron/main.js\"",
    "electron:preview": "npm run build && tsc -p electron/tsconfig.json && cross-env NODE_ENV=production electron electron/main.js",
    "electron:build": "npm run build && tsc -p electron/tsconfig.json && electron-builder --dir",
    "package:mac": "npm run build && tsc -p electron/tsconfig.json && electron-builder --mac",
    "package:win": "npm run build && tsc -p electron/tsconfig.json && electron-builder --win",
    "package:linux": "npm run build && tsc -p electron/tsconfig.json && electron-builder --linux",
    "fetch:art": "node scripts/fetch-art.mjs",
    "bake:characters": "node scripts/bake-characters.mjs",
    "upload:steam": "node scripts/upload-steam.mjs",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@babylonjs/core": "^7.41.0",
    "@babylonjs/gui": "^7.41.0",
    "@babylonjs/loaders": "^7.41.0",
    "@babylonjs/materials": "^7.41.0",
    "@babylonjs/post-processes": "^7.41.0",
    "electron-store": "^10.0.1"
  },
  "devDependencies": {
    "@babylonjs/inspector": "^7.41.0",
    "@types/node": "^22.7.0",
    "concurrently": "^9.1.0",
    "cross-env": "^7.0.3",
    "electron": "^33.2.0",
    "electron-builder": "^25.1.8",
    "typescript": "^5.6.0",
    "vite": "^5.4.0",
    "wait-on": "^8.0.1"
  },
  "optionalDependencies": {
    "steamworks.js": "^0.4.0"
  },
  "engines": { "node": ">=18" },
  "build": {
    "appId": "com.abyss.desktop",
    "productName": "Abyss",
    "artifactName": "${productName}-${version}-${os}-${arch}.${ext}",
    "copyright": "Copyright © 2026 Eden Adiv",
    "directories": { "output": "release", "buildResources": "build" },
    "files": [
      "dist/**/*",
      "electron/**/*.js",
      "electron/**/*.cjs",
      "!**/*.map",
      "!**/*.ts",
      "node_modules/electron-store/**/*",
      "node_modules/steamworks.js/**/*"
    ],
    "asarUnpack": ["**/*.node", "node_modules/steamworks.js/**/*"],
    "extraResources": [{ "from": "steam_appid.txt", "to": "steam_appid.txt" }],
    "win": {
      "target": [{ "target": "nsis", "arch": ["x64"] }],
      "icon": "build/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "shortcutName": "Abyss"
    },
    "mac": {
      "target": [{ "target": "dmg", "arch": ["universal"] }],
      "icon": "build/icon.icns",
      "category": "public.app-category.role-playing-games",
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "entitlements": "build/entitlements.mac.plist",
      "entitlementsInherit": "build/entitlements.mac.plist"
    },
    "linux": {
      "target": [{ "target": "AppImage", "arch": ["x64"] }],
      "icon": "build/icon.png",
      "category": "Game"
    }
  }
}
